<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador de Senhas Pro</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #111827, #312e81);
            color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            background-color: #1f2937;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 400px;
            border: 1px solid #374151;
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #818cf8;
        }

        .output-area {
            background-color: #111827;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #4b5563;
        }

        #passwordDisplay {
            font-family: 'Consolas', monospace;
            font-size: 1.15rem;
            color: #10b981;
            word-break: break-all;
        }

        .btn-copy {
            background-color: #4f46e5;
            border: none;
            color: white;
            padding: 6px 12px;
            cursor: pointer;
            border-radius: 6px;
            font-size: 0.85rem;
            transition: background 0.2s;
        }

        .btn-copy:hover {
            background-color: #6366f1;
        }

        .option {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            font-size: 0.95rem;
        }

        input[type="number"] {
            background-color: #111827;
            border: 1px solid #4b5563;
            color: white;
            padding: 5px;
            border-radius: 6px;
            width: 55px;
            text-align: center;
        }

        input[type="checkbox"] {
            accent-color: #818cf8;
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .btn-main {
            display: block;
            width: 100%;
            background-color: #818cf8;
            color: #111827;
            border: none;
            padding: 14px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 25px;
        }

        .btn-main:hover {
            background-color: #a5b4fc;
            transform: translateY(-1px);
        }
    </style>
</head>
<body>

    <div class="card">
        <h2>Gerador de Senhas</h2>
        
        <div class="output-area">
            <span id="passwordDisplay">Clique em Gerar</span>
            <button class="btn-copy" onclick="copiarSenha()">Copiar</button>
        </div>

        <div class="options">
            <div class="option">
                <label>Tamanho</label>
                <input type="number" id="length" min="6" max="32" value="14">
            </div>
            <div class="option">
                <label>Letras Minúsculas</label>
                <input type="checkbox" id="minusculas" checked>
            </div>
            <div class="option">
                <label>Letras Maiúsculas</label>
                <input type="checkbox" id="maiusculas" checked>
            </div>
            <div class="option">
                <label>Números</label>
                <input type="checkbox" id="numeros" checked>
            </div>
            <div class="option">
                <label>Símbolos</label>
                <input type="checkbox" id="simbolos" checked>
            </div>
        </div>

        <button class="btn-main" onclick="gerarSenha()">Gerar Senha</button>
    </div>

    <script>
        function gerarSenha() {
            const length = parseInt(document.getElementById('length').value);
            const hasLower = document.getElementById('minusculas').checked;
            const hasUpper = document.getElementById('maiusculas').checked;
            const hasNumber = document.getElementById('numeros').checked;
            const hasSymbol = document.getElementById('simbolos').checked;

            const lowerChars = "abcdefghijklmnopqrstuvwxyz";
            const upperChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            const numberChars = "0123456789";
            const symbolChars = "!@#$%^&*()_+~`|}{[]\\:;?><,./-=";

            let charPool = "";
            let passwordChars = [];

            // Garante que pelo menos um caractere de cada tipo selecionado entre na senha
            if (hasLower) {
                charPool += lowerChars;
                passwordChars.push(lowerChars[Math.floor(Math.random() * lowerChars.length)]);
            }
            if (hasUpper) {
                charPool += upperChars;
                passwordChars.push(upperChars[Math.floor(Math.random() * upperChars.length)]);
            }
            if (hasNumber) {
                charPool += numberChars;
                passwordChars.push(numberChars[Math.floor(Math.random() * numberChars.length)]);
            }
            if (hasSymbol) {
                charPool += symbolChars;
                passwordChars.push(symbolChars[Math.floor(Math.random() * symbolChars.length)]);
            }

            if (charPool === "") {
                document.getElementById('passwordDisplay').innerText = "Selecione uma opção!";
                return;
            }

            // Preenche o resto do tamanho da senha sorteando do pool de caracteres
            while (passwordChars.length < length) {
                const randomChar = charPool[Math.floor(Math.random() * charPool.length)];
                passwordChars.push(randomChar);
            }

            // Embaralha a array para evitar padrões previsíveis no início da senha
            passwordChars = passwordChars.sort(() => Math.random() - 0.5);

            // Exibe a senha na tela
            document.getElementById('passwordDisplay').innerText = passwordChars.join('');
        }

        function copiarSenha() {
            const texto = document.getElementById('passwordDisplay').innerText;
            if(texto !== "Clique em Gerar" && texto !== "Selecione uma opção!") {
                navigator.clipboard.writeText(texto);
                alert("Senha copiada para a área de transferência!");
            }
        }
    </script>
</body>
</html>
